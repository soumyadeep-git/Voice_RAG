# --- LLM provider (any OpenAI-compatible endpoint) ---
# Default: Cerebras (free tier, very fast, serves Llama-3.3-70B).
LLM_PROVIDER=cerebras
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_API_KEY=
# gpt-oss-120b is available on the Cerebras free tier; run
# `GET /v1/models` to see what your key can access.
ANSWER_MODEL=gpt-oss-120b
FAST_MODEL=gpt-oss-120b

# To use Groq instead, swap the three lines above for:
#   LLM_PROVIDER=groq
#   LLM_BASE_URL=https://api.groq.com/openai/v1
#   ANSWER_MODEL=llama-3.3-70b-versatile
#   FAST_MODEL=llama-3.1-8b-instant
# Any other OpenAI-compatible host (OpenRouter, Together, local Ollama) works the same way.

# --- Speech-to-text (Groq Whisper) ---
# Browser STT handles live interim text + barge-in; the final utterance is
# transcribed here for accuracy. Uses its own endpoint/key (the chat provider
# may not serve audio). Leave STT_API_KEY empty to stay browser-only.
STT_BASE_URL=https://api.groq.com/openai/v1
STT_API_KEY=
STT_MODEL=whisper-large-v3-turbo

# --- Text-to-speech (Cartesia; natural voice) ---
# Leave CARTESIA_API_KEY empty to use the browser's built-in voice instead.
# Leave CARTESIA_VOICE_ID empty to auto-pick a female English voice.
CARTESIA_API_KEY=
CARTESIA_MODEL=sonic-2
CARTESIA_VOICE_ID=

EMBED_MODEL=BAAI/bge-small-en-v1.5

RETRIEVAL_CANDIDATES=20
RETRIEVAL_TOP_K=5
ENABLE_RERANK=true
RERANK_MODEL=Xenova/ms-marco-MiniLM-L-6-v2

DATA_DIR=data
CHROMA_DIR=storage/chroma
SQLITE_PATH=storage/app.sqlite

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
